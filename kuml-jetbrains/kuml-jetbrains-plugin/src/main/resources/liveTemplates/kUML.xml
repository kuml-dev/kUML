<templateSet group="kUML">
    <template name="uml" value="umlModel {&#10;    $END$&#10;}" description="kUML: empty umlModel { … } block" toReformat="true" toShortenFQNames="true">
        <context><option name="KOTLIN" value="true"/></context>
    </template>
    <template name="c4" value="c4Model(name = &quot;$NAME$&quot;) {&#10;    $END$&#10;}" description="kUML: empty c4Model { … } block" toReformat="true" toShortenFQNames="true">
        <variable name="NAME" expression="" defaultValue="&quot;MySystem&quot;" alwaysStopAt="true"/>
        <context><option name="KOTLIN" value="true"/></context>
    </template>
    <template name="sysml" value="sysml2Model {&#10;    $END$&#10;}" description="kUML: empty sysml2Model { … } block" toReformat="true" toShortenFQNames="true">
        <context><option name="KOTLIN" value="true"/></context>
    </template>
    <template name="classdiag" value="classDiagram(&quot;$NAME$&quot;) {&#10;    classOf(name = &quot;$CLASS$&quot;) {&#10;        $END$&#10;    }&#10;}" description="kUML: classDiagram with one classOf" toReformat="true" toShortenFQNames="true">
        <variable name="NAME" expression="" defaultValue="&quot;MyDiagram&quot;" alwaysStopAt="true"/>
        <variable name="CLASS" expression="" defaultValue="&quot;MyClass&quot;" alwaysStopAt="true"/>
        <context><option name="KOTLIN" value="true"/></context>
    </template>
    <template name="clazz" value="classOf(name = &quot;$NAME$&quot;) {&#10;    $END$&#10;}" description="kUML: classOf(name = …) { … }" toReformat="true" toShortenFQNames="true">
        <variable name="NAME" expression="" defaultValue="&quot;User&quot;" alwaysStopAt="true"/>
        <context><option name="KOTLIN" value="true"/></context>
    </template>
    <template name="iface" value="interfaceOf(name = &quot;$NAME$&quot;) {&#10;    $END$&#10;}" description="kUML: interfaceOf(name = …) { … }" toReformat="true" toShortenFQNames="true">
        <variable name="NAME" expression="" defaultValue="&quot;Payable&quot;" alwaysStopAt="true"/>
        <context><option name="KOTLIN" value="true"/></context>
    </template>
    <template name="enumc" value="enumOf(name = &quot;$NAME$&quot;) {&#10;    literal(&quot;$LIT$&quot;)&#10;    $END$&#10;}" description="kUML: enumOf(name = …) { literal(…) }" toReformat="true" toShortenFQNames="true">
        <variable name="NAME" expression="" defaultValue="&quot;Status&quot;" alwaysStopAt="true"/>
        <variable name="LIT" expression="" defaultValue="&quot;ACTIVE&quot;" alwaysStopAt="true"/>
        <context><option name="KOTLIN" value="true"/></context>
    </template>
    <template name="sm" value="stateMachine(&quot;$NAME$&quot;) {&#10;    stateDef(&quot;Idle&quot;)&#10;    stateDef(&quot;$STATE$&quot;)&#10;    $END$&#10;}" description="kUML: stateMachine(…) with two stateDefs" toReformat="true" toShortenFQNames="true">
        <variable name="NAME" expression="" defaultValue="&quot;OrderFSM&quot;" alwaysStopAt="true"/>
        <variable name="STATE" expression="" defaultValue="&quot;Active&quot;" alwaysStopAt="true"/>
        <context><option name="KOTLIN" value="true"/></context>
    </template>
    <template name="part" value="partDef(&quot;$NAME$&quot;) {&#10;    $END$&#10;}" description="kUML: SysML 2 partDef(…) { … }" toReformat="true" toShortenFQNames="true">
        <variable name="NAME" expression="" defaultValue="&quot;Vehicle&quot;" alwaysStopAt="true"/>
        <context><option name="KOTLIN" value="true"/></context>
    </template>
    <template name="c4ctx" value="systemContext(&quot;$NAME$&quot;) {&#10;    person(&quot;User&quot;)&#10;    softwareSystem(&quot;$SYS$&quot;)&#10;    $END$&#10;}" description="kUML: C4 systemContext diagram" toReformat="true" toShortenFQNames="true">
        <variable name="NAME" expression="" defaultValue="&quot;Context&quot;" alwaysStopAt="true"/>
        <variable name="SYS" expression="" defaultValue="&quot;BankingSystem&quot;" alwaysStopAt="true"/>
        <context><option name="KOTLIN" value="true"/></context>
    </template>
    <template name="attr" value="attributeOf(name = &quot;$NAME$&quot;, type = typeRef(&quot;$TYPE$&quot;))$END$" description="kUML: attributeOf inside classOf { }" toReformat="true" toShortenFQNames="true">
        <variable name="NAME" expression="" defaultValue="&quot;name&quot;" alwaysStopAt="true"/>
        <variable name="TYPE" expression="" defaultValue="&quot;String&quot;" alwaysStopAt="true"/>
        <context><option name="KOTLIN" value="true"/></context>
    </template>
    <template name="port" value="portDef(&quot;$NAME$&quot;)" description="kUML: SysML 2 portDef(…)" toReformat="true" toShortenFQNames="true">
        <variable name="NAME" expression="" defaultValue="&quot;powerIn&quot;" alwaysStopAt="true"/>
        <context><option name="KOTLIN" value="true"/></context>
    </template>
</templateSet>
