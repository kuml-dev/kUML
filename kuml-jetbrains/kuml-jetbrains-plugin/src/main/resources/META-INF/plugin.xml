<idea-plugin>
    <id>dev.kuml.intellij</id>
    <name>kUML</name>
    <vendor email="dev@kuml.dev" url="https://kuml.dev">kUML</vendor>

    <description><![CDATA[
        <h3>kUML — Kotlin-based UML &amp; C4 modelling</h3>
        <p>
            Adds first-class IntelliJ support for kUML diagram scripts (<code>*.kuml.kts</code>):
        </p>
        <ul>
            <li>
                Recognises <code>*.kuml.kts</code> as a custom Kotlin script kind via the
                <code>org.jetbrains.kotlin.scriptDefinitionsProvider</code> extension point.
            </li>
            <li>
                Syntax highlighting and structural navigation are inherited from IntelliJ's
                Kotlin language support — no custom lexer or parser.
            </li>
            <li>
                Default imports for the kUML DSL (<code>dev.kuml.core.dsl.*</code>,
                <code>dev.kuml.uml.dsl.*</code>, <code>dev.kuml.c4.dsl.*</code>) are visible
                to the editor, so unqualified <code>classDiagram { ... }</code>,
                <code>c4Model { ... }</code>, and friends resolve without explicit imports.
            </li>
            <li>
                Distinct file icon for kUML scripts.
            </li>
        </ul>
        <p>
            Rendering, code generation, OCL validation, and state-machine simulation are
            provided by the <code>kuml</code> CLI and the <code>dev.kuml</code> Gradle plugin —
            this IDE plugin is intentionally minimal and stays out of the render pipeline.
        </p>
        <p>
            Project page: <a href="https://kuml.dev">https://kuml.dev</a>.
        </p>
    ]]></description>

    <change-notes><![CDATA[
        <!-- Diese Datei wird beim Build durch patchPluginXml überschrieben.
             Maßgeblich sind die changeNotes in build.gradle.kts. -->
        <h4>0.8.0</h4>
        <ul>
            <li>K2-Kompatibilität: Plugin läuft wieder in IntelliJ 2024.x+ mit aktivem K2-Frontend.</li>
            <li>Versions-Alignment: Plugin-Version folgt dem kUML-Monorepo.</li>
        </ul>
        <h4>0.4.1</h4>
        <ul>
            <li>Code completion für kUML-DSL-Top-Level-Funktionen (42 Items).</li>
            <li>Rename Refactoring (Shift+F6) für DSL-Element-Namen.</li>
            <li>Live Templates (12 Templates).</li>
        </ul>
        <h4>0.3.0</h4>
        <ul>
            <li>Code Folding für DSL-Lambda-Blöcke.</li>
        </ul>
        <h4>0.2.0</h4>
        <ul>
            <li>Live-SVG Split-View, Structure View, External Annotator + Quick Fixes.</li>
        </ul>
        <h4>0.1.0</h4>
        <ul>
            <li>Initiale Version: Script-Definition Provider, Dateityp-Registrierung, Datei-Icon.</li>
        </ul>
    ]]></change-notes>

    <!--
        Compatibility:
        sinceBuild is in build.gradle.kts (intellijPlatform.pluginConfiguration.ideaVersion).
        We depend on the Kotlin plugin because we use its scriptDefinitionsProvider EP.
    -->
    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <!--
            K2-Kompatibilität: Seit IntelliJ 2024.x ist K2 der Default-Frontend des
            Kotlin-Plugins. Plugins, die `depends`-on org.jetbrains.kotlin sind, müssen
            explizit deklarieren, welche Modi sie unterstützen — sonst werden sie im
            K2-Mode automatisch deaktiviert ("Plugin is incompatible with the Kotlin
            plugin in 'K2' mode").

            Dieses Plugin benutzt KEINE K1-Resolve-APIs (keine Imports aus
            `org.jetbrains.kotlin.idea.*`, `org.jetbrains.kotlin.resolve.*`,
            `BindingContext`, `KotlinType` etc.). Es stützt sich ausschließlich auf:
              - `com.intellij.*` Platform-APIs (K2-agnostisch),
              - `kotlin.script.experimental.*` Scripting-API (in beiden Modi identisch),
              - PSI-Elemente (KtFile/KtCallExpression — Parser-Output ist shared).

            Damit ist das Plugin in beiden Modi lauffähig.
        -->
        <supportsKotlinPluginMode supportsK1="true" supportsK2="true"/>

        <!--
            Registers the kUML script definition with the Kotlin plugin via the
            K2-native `scriptDefinitionsSource` extension point (interface
            org.jetbrains.kotlin.scripting.definitions.ScriptDefinitionsSource).

            This replaces the legacy `scriptDefinitionsProvider` EP, which in
            IntelliJ 2025.1+/build 261 K2 mode is only reached through the
            BridgeScriptDefinitionsContributor shim — and that shim fails to
            instantiate a no-arg provider ("Cannot find suitable constructor,
            expected (Project), …"), so `*.kuml.kts` was never recognised.

            `scriptDefinitionsSource` is consumed in BOTH K1 and K2 modes (JetBrains'
            own Gradle/main.kts definitions use it), so this one registration works
            across every IntelliJ configuration. See KumlScriptDefinitionsSource.
        -->
        <scriptDefinitionsSource
            implementation="dev.kuml.jetbrains.KumlScriptDefinitionsSource"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <!--
            Custom file icon for `*.kuml.kts`.
            The actual file type is "Kotlin script" (registered by the Kotlin plugin) —
            we only override the icon for files matching the kUML extension.
        -->
        <fileIconProvider
            implementation="dev.kuml.jetbrains.KumlFileIconProvider"
            order="first"/>

        <externalAnnotator language="kotlin" implementationClass="dev.kuml.jetbrains.KumlAnnotator"/>

        <!--
            V2.0.28b: Split-editor — shows the diagram SVG alongside the code editor.
            Registered with editorTypeId = "kuml-split-editor".
        -->
        <fileEditorProvider implementation="dev.kuml.jetbrains.KumlSplitEditorProvider"/>

        <!--
            Settings → Tools → kUML Preview: configure the path to the external
            `kuml` CLI used to render previews (empty = auto-detect).
        -->
        <applicationConfigurable
            parentId="tools"
            instance="dev.kuml.jetbrains.KumlPreviewConfigurable"
            id="dev.kuml.jetbrains.KumlPreviewConfigurable"
            displayName="kUML Preview"/>

        <!--
            V2.0.28b: Structure view — shows DSL elements (states, parts, classes …)
            extracted from the script text in the Structure panel.
            Registered for the Kotlin language since *.kuml.kts are parsed as Kotlin scripts.
        -->
        <lang.psiStructureViewFactory
            language="kotlin"
            implementationClass="dev.kuml.jetbrains.KumlStructureViewBuilderProvider"/>

        <!--
            V2.0.28c: Code folding — collapses DSL lambda blocks in *.kuml.kts files.
            Registered for the Kotlin language (same reason as the structure view above).
            The builder guards against non-.kuml.kts files internally.
        -->
        <lang.foldingBuilder
            language="kotlin"
            implementationClass="dev.kuml.jetbrains.folding.KumlFoldingBuilder"/>

        <!--
            V2.0.41: Live Templates — kUML.xml wird automatisch geladen.
        -->
        <defaultLiveTemplates file="/liveTemplates/kUML.xml"/>

        <!--
            V2.0.41: Code-Completion für kUML-DSL Top-Level-Funktionen.
            Der Contributor diskriminiert intern auf .kuml.kts-Dateinamen.
        -->
        <completion.contributor
            language="kotlin"
            implementationClass="dev.kuml.jetbrains.completion.KumlCompletionContributor"
            order="first"/>

        <!--
            V2.0.41: Rename Refactoring (Shift+F6) für DSL-Element-Namen.
        -->
        <renameHandler
            implementation="dev.kuml.jetbrains.rename.KumlRenameHandler"/>
    </extensions>
</idea-plugin>
