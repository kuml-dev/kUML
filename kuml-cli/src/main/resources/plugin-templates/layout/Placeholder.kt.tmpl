 *
 * Generated by `kuml plugin init layout`. Implement [NoOpLayoutEngine.layout] below,
 * then `./gradlew build`.
 */
public class {{className}} : KumlLayoutPlugin {
    override val descriptor: PluginDescriptor =
        PluginDescriptor(
            id = "{{pluginId}}",
            name = "{{pluginName}}",
            version = PluginVersion(1, 0, 0),
            kumlVersionRange = KumlVersionRange("{{kumlVersionRange}}"),
            capabilities = setOf(PluginCapability.LAYOUT),
            maintainer = "{{maintainer}}",
            homepage = "{{homepage}}",
            licenseSpdx = "{{licenseSpdx}}",
        )

    override fun engines(): List<KumlLayoutEngine> = listOf(NoOpLayoutEngine())
}

/**
 * Minimal stub — replace with your real layout algorithm.
 *
 * Returns every node at position (0,0) with its intrinsic size.
 * All edges are routed as straight direct connections.
 */
public class NoOpLayoutEngine : KumlLayoutEngine {
    override val id: LayoutEngineId = LayoutEngineId("{{artifactId}}")

    override val capabilities: LayoutCapabilities =
        LayoutCapabilities(
            deterministic = true,
            supportedDiagramKinds = setOf(DiagramKind.Generic),
            supportedEdgeStyles = setOf(EdgeRouteStyle.Direct),
            respectsGridHints = false,
            respectsRelativeConstraints = false,
            maxRecommendedNodes = 100,
        )

    override fun layout(
        graph: LayoutGraph,
        hints: LayoutHints,
    ): LayoutResult {
        // TODO: implement your layout algorithm
        val nodeLayouts =
            graph.nodes.associate { node ->
                node.id to
                    dev.kuml.layout.NodeLayout(
                        bounds =
                            dev.kuml.layout.Rect(
                                origin = dev.kuml.layout.Point(x = 0f, y = 0f),
                                size = node.intrinsicSize,
                            ),
                        ports = emptyMap(),
                    )
            }
        val edgeRoutes =
            graph.edges.associate { edge ->
                edge.id to EdgeRoute.Direct
            }
        return LayoutResult(
            engineId = id,
            seed = hints.deterministicSeed,
            canvas = dev.kuml.layout.Size(width = 800f, height = 600f),
            nodes = nodeLayouts,
            edges = edgeRoutes,
            groups = emptyMap(),
        )
    }
}
