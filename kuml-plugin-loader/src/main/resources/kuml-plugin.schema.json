{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kuml.dev/schemas/kuml-plugin.schema.json",
  "title": "kUML Plugin Manifest",
  "description": "Schema for kuml-plugin.json manifests (schema version 1)",
  "type": "object",
  "required": ["schemaVersion", "id", "name", "version", "kumlVersionRange", "extensions"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "kumlVersionRange": { "type": "string", "minLength": 1 },
    "extensions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["category", "implementation", "id"],
        "properties": {
          "category": {
            "type": "string",
            "enum": ["theme", "renderer", "layout", "codegen", "reverse"]
          },
          "implementation": { "type": "string", "minLength": 1 },
          "id": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "permissions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "maintainer": { "type": "string" },
    "homepage": { "type": "string" },
    "licenseSpdx": { "type": "string" },
    "signature": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
