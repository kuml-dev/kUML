# kUML Environment Variables
# -----------------------------------------------------------
# Kopiere diese Datei zu .env und fülle die Werte aus.
# WICHTIG: .env niemals in Git committen!
# -----------------------------------------------------------

# Anthropic API Key — benötigt für den LLM-Benchmark
# Erzeugen unter: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: Benchmark-Modell überschreiben (Standard: claude-sonnet-4-5)
# KUML_BENCH_MODEL=claude-opus-4-0
